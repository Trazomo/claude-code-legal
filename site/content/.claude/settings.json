{
  // Permissions scoped for law firm security
  "permissions": {
    "allow": [
      // File access limited to matter files and templates
      "Read /matters/**",
      "Read /templates/**",
      "Write /matters/**",
      "Write /templates/**",
      // Research tools
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      // Block shell commands that could leak confidential data
      "Bash curl *",
      "Bash wget *",
      "Bash ssh *",
      "Bash scp *",
      // Prevent writing outside approved directories
      "Write /etc/**",
      "Write /usr/**"
    ]
  },

  // Approved MCP servers for this project
  "mcpServers": {
    "approved": [
      "filesystem",    // Local file access (scoped to /matters/ and /templates/)
      "postgres",      // Matter management database
      "web-search"     // Case law research (logged for audit)
    ]
  },

  // Safety: require confirmation for these actions
  "requireConfirmation": [
    "Delete any file",
    "Modify files outside /matters/ and /templates/",
    "Execute shell commands",
    "Send data to external services"
  ]
}
