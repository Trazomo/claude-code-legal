{
  // .mcp.json — Project-scope MCP configuration
  //
  // MCP (Model Context Protocol) connects Claude to external tools,
  // APIs, and data sources. Each "server" exposes a set of tools
  // that Claude can discover and call during a session.
  //
  // This file lives at your project root. Commit it to version
  // control so every team member gets the same tool configuration.
  //
  // Three server types are supported:
  //   "http"    — Remote HTTP server (recommended for remote tools)
  //   "command" — Local stdio process (spawned per session)
  //   "url"     — SSE endpoint (deprecated, use http instead)
  //
  // Install servers from the CLI instead of editing this by hand:
  //   claude mcp add my-server -s project -- npx some-mcp-package
  //
  // Scopes control who sees each server:
  //   -s local    — Just you, this machine (~/.claude.json)
  //   -s project  — Everyone on the project (.mcp.json, committed)
  //   -s user     — Just you, all your projects (~/.claude/settings.json)
  //
  // Manage servers in a session with the /mcp slash command.

  "mcpServers": {

    // ── HTTP server (recommended for remote services) ──────────
    // Connects to a remote HTTP endpoint. Supports OAuth if the
    // server requires authentication. Claude handles the flow.
    "my-remote-service": {
      "type": "http",
      "url": "https://my-service.example.com/mcp"
    },

    // ── stdio server (for local tools) ─────────────────────────
    // Spawns a local process. Claude communicates via stdin/stdout.
    // Most npm/pip MCP packages use this transport.
    "my-local-tool": {
      "command": "npx",
      "args": ["-y", "@example/mcp-server-tool"],
      "env": {
        // Environment variables support expansion syntax:
        //   ${env:VAR}            — reads from your shell environment
        //   ${env:VAR:-default}   — falls back to "default" if unset
        "API_KEY": "${env:MY_TOOL_API_KEY}",
        "DATABASE_URL": "${env:DATABASE_URL:-postgresql://localhost:5432/mydb}"
      },
      // Optional: set the working directory for the spawned process
      "cwd": "/path/to/working/directory"
    },

    // ── Real-world examples ────────────────────────────────────
    // Popular community servers you might add:
    //
    //   claude mcp add github -s project -- npx -y @modelcontextprotocol/server-github
    //   claude mcp add postgres -s local -- npx -y @modelcontextprotocol/server-postgres
    //   claude mcp add sentry -s project -- npx -y @sentry/mcp-server-sentry
    //
    // Browse available servers: https://github.com/modelcontextprotocol/servers

    // ── Tool Search ────────────────────────────────────────────
    // When MCP servers expose many tools, Claude uses Tool Search
    // to find the right ones instead of loading them all. This
    // happens automatically for servers with 30+ tools. To adjust:
    //
    //   "toolSearch": {
    //     "enabled": "auto",        — "auto" (default), true, or false
    //     "threshold": 30           — tool count that triggers search
    //   }

    // ── MCP Resources ──────────────────────────────────────────
    // Some servers expose data as resources (docs, schemas, etc.).
    // Reference them in your prompt with @server-name:resource-id
    // to pull that data into context.

    // ── MCP Prompts ────────────────────────────────────────────
    // Servers can expose reusable prompt templates that appear as
    // slash commands. Run /mcp in a session to see available prompts.
  }
}